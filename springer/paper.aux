\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}Baseline Results: Pre-COVID Period}{12}{subsection.5.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Robustness of price elasticity across control specifications (pre-COVID, 2010--2019). EaP elasticity is significant at p$<$0.01 in all specifications ($-0.63$ to $-0.57$). EU elasticity ranges from $-0.14$ to $-0.03$. Error bars show 90\% confidence intervals; bars excluding zero correspond to p$<$0.10.}}{13}{figure.1}\protected@file@percent }
\newlabel{fig:robustness_specs}{{1}{13}{Robustness of price elasticity across control specifications (pre-COVID, 2010--2019). EaP elasticity is significant at p$<$0.01 in all specifications ($\EaPSpecMin $ to $\EaPSpecMax $). EU elasticity ranges from $\EUSpecMin $ to $\EUSpecMax $. Error bars show 90\% confidence intervals; bars excluding zero correspond to p$<$0.10}{figure.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Robustness to Price Measurement}{13}{subsection.5.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}COVID-19 Period: Structural Change}{13}{subsection.5.3}\protected@file@percent }
\citation{oecd2021broadband}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Disappearance of price elasticity during COVID-19. Pre-COVID elasticities are significantly negative (EU: $-0.19$**, EaP: $-0.36$***; full-sample model), while COVID-era elasticities are statistically insignificant. Both shifts are significant at p$<$0.01. Error bars show 90\% confidence intervals; bars excluding zero correspond to p$<$0.10. Pre-COVID coefficients derive from the full 2010--2024 panel; pure pre-COVID subsample estimates are EU $=-0.10$ and EaP $=-0.60$ (Online Appendix Table~A1).}}{14}{figure.2}\protected@file@percent }
\newlabel{fig:covid_comparison}{{2}{14}{Disappearance of price elasticity during COVID-19. Pre-COVID elasticities are significantly negative (EU: $\EUPreIntB $\EUPreIntStars , EaP: $\EaPPreIntB $\EaPPreIntStars ; full-sample model), while COVID-era elasticities are statistically insignificant. Both shifts are significant at p$<$0.01. Error bars show 90\% confidence intervals; bars excluding zero correspond to p$<$0.10. Pre-COVID coefficients derive from the full 2010--2024 panel; pure pre-COVID subsample estimates are EU $=\EUBaseBr $ and EaP $=\EaPBaseBr $ (Online Appendix Table~A1)}{figure.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}Period-Split: Acute COVID vs.\ Post-Acute}{14}{subsection.5.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.5}Temporal Evolution: Year-by-Year Analysis}{15}{subsection.5.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.6}Placebo Test: Pre-Trends}{15}{subsection.5.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Temporal evolution of EU broadband price elasticity (2015--2024). Year-by-year estimates for EU countries (N$=$27) using 2010--2014 as the reference period; standard errors via the delta method using the full covariance matrix. Filled markers indicate p$<$0.05; open markers indicate p$\geq $0.05. Shaded region marks the COVID period (2020--2024). EaP is excluded: with only five to six EaP countries the annual triple interaction is identified from too few cross-sectional units and is confounded with EaP-bloc-specific shocks; EaP pre-trend evidence is provided by the pooled placebo test (Online Appendix Table~A4).}}{16}{figure.3}\protected@file@percent }
\newlabel{fig:temporal_evolution}{{3}{16}{Temporal evolution of EU broadband price elasticity (2015--2024). Year-by-year estimates for EU countries (N$=$27) using 2010--2014 as the reference period; standard errors via the delta method using the full covariance matrix. Filled markers indicate p$<$0.05; open markers indicate p$\geq $0.05. Shaded region marks the COVID period (2020--2024). EaP is excluded: with only five to six EaP countries the annual triple interaction is identified from too few cross-sectional units and is confounded with EaP-bloc-specific shocks; EaP pre-trend evidence is provided by the pooled placebo test (Online Appendix Table~A4)}{figure.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.7}Robustness Matrix: Comprehensive Validation}{16}{subsection.5.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Placebo test for pre-COVID trends. (a) EU three-phase evolution of elasticity (2010--2014 reference from the interaction model; 2015--2019 and 2020--2024 from year-by-year averages, EU N$=$27). EaP is excluded from Panel~(a) for the same reason it is excluded from Figure~\ref {fig:temporal_evolution}: with only five to six EaP countries the year-by-year phase averages are confounded with EaP-bloc-specific shocks. (b) Pooled placebo coefficients: both EU (p$=$0.057) and EaP (p$=$0.086) effects are marginally significant at the 10\% level, indicating pre-existing trend attenuation in both regions.}}{17}{figure.4}\protected@file@percent }
\newlabel{fig:placebo_test}{{4}{17}{Placebo test for pre-COVID trends. (a) EU three-phase evolution of elasticity (2010--2014 reference from the interaction model; 2015--2019 and 2020--2024 from year-by-year averages, EU N$=$27). EaP is excluded from Panel~(a) for the same reason it is excluded from Figure~\ref {fig:temporal_evolution}: with only five to six EaP countries the year-by-year phase averages are confounded with EaP-bloc-specific shocks. (b) Pooled placebo coefficients: both EU (p$=$\PlaceboEUPval ) and EaP (p$=$\PlaceboEaPPval ) effects are marginally significant at the 10\% level, indicating pre-existing trend attenuation in both regions}{figure.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.8}Economic Interpretation}{17}{subsection.5.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces EaP elasticity across 24{} specifications (8 control configurations $\times $ 3 price measures, pre-COVID). Darker shading indicates stronger negative elasticity. Significance: ***p$<$0.01, **p$<$0.05, *p$<$0.10. GNI\% range: $-0.63$ to $-0.57$, demonstrating robustness to modeling choices.}}{18}{figure.5}\protected@file@percent }
\newlabel{fig:results_matrix}{{5}{18}{EaP elasticity across \RobNSpecs {} specifications (8 control configurations $\times $ 3 price measures, pre-COVID). Darker shading indicates stronger negative elasticity. Significance: ***p$<$0.01, **p$<$0.05, *p$<$0.10. GNI\% range: $\RobEaPMin $ to $\RobEaPMax $, demonstrating robustness to modeling choices}{figure.5}{}}
